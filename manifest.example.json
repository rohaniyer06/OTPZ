{
    "manifest_version": 3,
    "name": "OTPZ",
    "version": "0.1.0",
    "description": "Fetch recent OTP codes from your Gmail and show them in a popup.",
    "permissions": [
        "identity",
        "storage",
        "activeTab",
        "scripting",
        "alarms",
        "offscreen"
    ],
    "host_permissions": [
        "https://www.googleapis.com/*",
        "https://accounts.google.com/*",
        "<all_urls>",
        "http://127.0.0.1:7483/*"
    ],
    "background": {
        "service_worker": "background/service_worker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icon.png"
    },
    "icons": {
        "128": "icon.png"
    },
    "oauth2": {
        "client_id": "YOUR_CLIENT_ID_HERE",
        "scopes": [
            "https://www.googleapis.com/auth/gmail.readonly"
        ]
    }
}